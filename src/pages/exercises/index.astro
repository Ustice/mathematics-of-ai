---
import { getCollection } from 'astro:content';
import { existsSync } from 'node:fs';
import path from 'node:path';
import SiteNav from '../../components/SiteNav.astro';
import '../../styles/lesson.css';
import {
  artifactFileName,
  buildLessonCatalog,
  readArtifactRecords,
  sourceArtifactUrl,
} from '../../lib/lesson-catalog';

const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (routePath: string) => `${basePath}${routePath.replace(/^\/+/, '')}`;
const lessonPages = await getCollection('lessons');
const lessons = buildLessonCatalog(
  lessonPages.map(({ data }) => data),
  readArtifactRecords(),
);
const imageCount = lessons.reduce((count, lesson) => count + lesson.exerciseImages.length, 0);
const reviewCount = lessons.filter(({ review }) => review !== null).length;
const fileExists = (relativePath: string) => existsSync(path.join(process.cwd(), relativePath));
const reviewUrl = (exerciseModule: string) => `/${exerciseModule}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Handwritten exercise images and historical review notes for the Mathematics of AI course." />
    <title>Exercises | Mathematics of AI</title>
  </head>
  <body>
    <main class="index-page">
      <SiteNav current="exercises" />
      <header class="index-header">
        <p class="eyebrow">Mathematics of AI</p>
        <h1>Exercises</h1>
        <p class="dek">
          Handwritten work organized by lesson, with each exported page available in reading order.
        </p>
        <dl class="metric-grid">
          <div>
            <dt>Images</dt>
            <dd>{imageCount}</dd>
          </div>
          <div>
            <dt>Historical Reviews</dt>
            <dd>{reviewCount}</dd>
          </div>
        </dl>
      </header>

      <section class="resource-table" aria-label="Exercise artifacts">
        <div class="resource-table-header">
          <span>Lesson</span>
          <span>Artifacts</span>
        </div>
        {
          lessons.map(({ artifacts, exerciseImages, lesson, review, title }) => (
            <article class="resource-row">
              <div>
                <p class="lesson-number">{`Lesson ${lesson}`}</p>
                <h2>{title}</h2>
              </div>
              <div class="resource-links">
                {
                  exerciseImages.length > 0 ? (
                    exerciseImages.map((artifactPath, index) => (
                      <a href={withBase(sourceArtifactUrl(artifactPath))}>
                        {`Page ${index + 1}: ${artifactFileName(artifactPath)}`}
                      </a>
                    ))
                  ) : (
                    <span>No exercise images committed</span>
                  )
                }
                {
                  review && artifacts.exercise_module && fileExists(review) ? (
                    <a href={withBase(reviewUrl(artifacts.exercise_module))}>Historical review</a>
                  ) : null
                }
              </div>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>
