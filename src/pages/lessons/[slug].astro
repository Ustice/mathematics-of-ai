---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ExerciseGallery from '../../components/ExerciseGallery.astro';
import LessonLayout from '../../layouts/LessonLayout.astro';
import { buildLessonCatalog, readArtifactRecords } from '../../lib/lesson-catalog';

type Props = {
  exerciseImages: string[];
  lesson: CollectionEntry<'lessons'>;
};

export const getStaticPaths = async () => {
  const lessons = await getCollection('lessons');
  const catalogByLesson = new Map(
    buildLessonCatalog(
      lessons.map(({ data }) => data),
      readArtifactRecords(),
    ).map((entry) => [entry.lesson, entry]),
  );

  return lessons.map((lesson) => ({
    params: { slug: lesson.data.slug },
    props: {
      exerciseImages: catalogByLesson.get(lesson.data.lesson)?.exerciseImages ?? [],
      lesson,
    },
  }));
};

const { exerciseImages, lesson } = Astro.props;
const { Content, headings } = await render(lesson);
---

<LessonLayout headings={headings} lesson={lesson.data}>
  <Content />
  <ExerciseGallery images={exerciseImages} />
</LessonLayout>
