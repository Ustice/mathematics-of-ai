---
const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const lessonsPath = `${basePath}lessons/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${lessonsPath}`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mathematics of AI</title>
  </head>
  <body>
    <a href={lessonsPath}>Lessons</a>
  </body>
</html>
