---
import { getCollection } from 'astro:content';
import SiteNav from '../components/SiteNav.astro';
import '../styles/lesson.css';
import { buildLessonCatalog, readArtifactRecords } from '../lib/lesson-catalog';

const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (routePath: string) => `${basePath}${routePath.replace(/^\/+/, '')}`;
const lessons = await getCollection('lessons');
const catalog = buildLessonCatalog(
  lessons.map(({ data }) => data),
  readArtifactRecords(),
);
const exerciseImageCount = catalog.reduce(
  (count, lesson) => count + lesson.exerciseImages.length,
  0,
);
const latestLesson = lessons
  .sort((left, right) => right.data.lesson - left.data.lesson)
  .at(0);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Course dashboard for Mathematics of AI lessons, exercises, and curriculum." />
    <title>Mathematics of AI</title>
  </head>
  <body>
    <main class="index-page">
      <SiteNav current="course" />
      <header class="index-header">
        <p class="eyebrow">Mathematics of AI</p>
        <h1>Mathematics for Machine Intelligence</h1>
        <p class="dek">
          A living course workspace for the math behind modern machine learning.
        </p>
        <dl class="metric-grid">
          <div>
            <dt>Lessons</dt>
            <dd>{lessons.length}</dd>
          </div>
          <div>
            <dt>Catalog Entries</dt>
            <dd>{catalog.length}</dd>
          </div>
          <div>
            <dt>Exercise Images</dt>
            <dd>{exerciseImageCount}</dd>
          </div>
        </dl>
      </header>

      <section class="dashboard-grid" aria-label="Course sections">
        <a class="dashboard-card" href={withBase('/lessons/')}>
          <p class="eyebrow">Read</p>
          <h2>Lessons</h2>
          <p>Canonical MDX Lesson Pages, including the latest: {latestLesson?.data.title ?? 'none yet'}.</p>
        </a>
        <a class="dashboard-card" href={withBase('/exercises/')}>
          <p class="eyebrow">Practice</p>
          <h2>Exercises</h2>
          <p>Handwritten exercise images organized by lesson, plus historical review notes.</p>
        </a>
        <a class="dashboard-card" href={withBase('/curriculum/')}>
          <p class="eyebrow">Plan</p>
          <h2>Curriculum</h2>
          <p>The current phase sequence, lesson order, completion checkpoint, and upcoming topics.</p>
        </a>
      </section>
    </main>
  </body>
</html>
