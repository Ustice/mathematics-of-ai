---
import 'katex/dist/katex.min.css';
import katex from 'katex';
import SiteNav from '../components/SiteNav.astro';
import '../styles/lesson.css';

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type LessonMeta = {
  description: string;
  lesson: number;
  objectives: string[];
  phase: string;
  prerequisites: Array<{
    lesson: number;
    title: string;
  }>;
  symbols: Array<{
    meaning: string;
    symbol: string;
  }>;
  title: string;
};

type Props = {
  headings: Heading[];
  lesson: LessonMeta;
};

const { headings, lesson } = Astro.props;
const tocItems = headings.filter(({ depth }) => depth === 2 || depth === 3);
const renderSymbol = (symbol: string) =>
  katex.renderToString(symbol, {
    output: 'htmlAndMathml',
    strict: 'error',
    throwOnError: true,
  });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={lesson.description} />
    <title>{`Lesson ${lesson.lesson}: ${lesson.title} | Mathematics of AI`}</title>
  </head>
  <body>
    <header class="lesson-header">
      <SiteNav current="lessons" />
      <p class="eyebrow">{lesson.phase}</p>
      <h1>{lesson.title}</h1>
      <p class="dek">{lesson.description}</p>
      <dl class="lesson-meta">
        <div>
          <dt>Lesson</dt>
          <dd>{lesson.lesson}</dd>
        </div>
      </dl>
    </header>
    <main class="lesson-shell">
      <aside class="lesson-panel" aria-label="Lesson objectives and prerequisites">
        <section>
          <h2>Objectives</h2>
          <ul>
            {lesson.objectives.map((objective) => <li>{objective}</li>)}
          </ul>
        </section>
        <section>
          <h2>Prerequisites</h2>
          <ul>
            {lesson.prerequisites.map((item) => <li>{`Lesson ${item.lesson}: ${item.title}`}</li>)}
          </ul>
        </section>
      </aside>
      <article class="lesson-content">
        <slot />
      </article>
      <aside class="lesson-panel lesson-panel-right" aria-label="Lesson table of contents and symbols">
        <section>
          <h2>Contents</h2>
          <nav class="toc" aria-label="Lesson contents">
            <ol>
              {
                tocItems.map((heading) => (
                  <li class={`toc-depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))
              }
            </ol>
          </nav>
        </section>
        <section>
          <h2>Symbols</h2>
          <dl class="symbol-list">
            {
              lesson.symbols.map((entry) => (
                <div>
                  <dt set:html={renderSymbol(entry.symbol)} />
                  <dd>{entry.meaning}</dd>
                </div>
              ))
            }
          </dl>
        </section>
      </aside>
    </main>
  </body>
</html>
